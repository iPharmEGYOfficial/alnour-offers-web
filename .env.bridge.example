# Bridge mode example
VITE_APP_NAME=AlNour Offers
VITE_APP_ENV=bridge
VITE_RUNTIME_MODE=bridge

# Bridge API
VITE_API_BASE_URL=http://localhost:5207
VITE_BRIDGE_BASE_URL=http://localhost:5207

# Optional bridge auth key
VITE_BRIDGE_KEY=your-bridge-key-here

# Data source behavior
VITE_USE_MOCK=false